<!DOCTYPE html>
<html>
<head>
    <title>Users - InnovaShield</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h1 { color: #3C3489; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        th { background: #3C3489; color: white; padding: 10px; }
        td { padding: 10px; border: 1px solid #ddd; }
        tr:nth-child(even) { background: #f2f2f2; }
        input, select { width: 100%; padding: 8px; margin: 5px 0; }
        button { background: #3C3489; color: white; padding: 10px 20px; border: none; cursor: pointer; }
        button:hover { background: #26215C; }
        .form-box { background: #f9f9f9; padding: 20px; border-radius: 8px; max-width: 500px; }
        label { font-weight: bold; display: block; margin-top: 10px; }
        a { color: #3C3489; }
    </style>
</head>
<body>
    <h1>Users</h1>

    <h2>All Users</h2>
    <table>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>User Type</th>
            <th>Created At</th>
            <th>Action</th>
        </tr>
        <% for(var i = 0; i < users.length; i++) { %>
        <tr>
            <td><%= users[i].user_id %></td>
            <td><%= users[i].name %></td>
            <td><%= users[i].email %></td>
            <td><%= users[i].user_type %></td>
            <td><%= users[i].created_at.toISOString().split('T')[0] %></td>
            <td><a href="/users/edit/<%= users[i].user_id %>">Edit</a></td>
        </tr>
        <% } %>
    </table>

    <% if (typeof editUser !== 'undefined') { %>
    <h2>Edit User</h2>
    <div class="form-box">
        <form action="/users/update" method="POST">
            <input type="hidden" name="user_id" value="<%= editUser.user_id %>">
            <label>Name:</label>
            <input type="text" name="name" value="<%= editUser.name %>" required>
            <label>Email:</label>
            <input type="email" name="email" value="<%= editUser.email %>" required>
            <label>User Type:</label>
            <select name="user_type">
                <option value="Entrepreneur">Entrepreneur</option>
                <option value="Student">Student</option>
                <option value="Inventor">Inventor</option>
                <option value="Researcher">Researcher</option>
                <option value="Legal Professional">Legal Professional</option>
            </select>
            <br><br>
            <button type="submit">Update User</button>
        </form>
    </div>
    <% } %>

</body>
</html>